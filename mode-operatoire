<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mode opératoire — Lexipaie</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a1a;
    --paper: #f5f2ed;
    --cream: #ede9e2;
    --accent: #c8521a;
    --accent-light: #f0e6dc;
    --muted: #7a7570;
    --border: #d4cfc8;
    --green: #2d6a4f;
    --green-light: #d8f3dc;
    --amber: #b5700a;
    --amber-light: #fef3c7;
    --red-light: #fde8e8;
    --red: #c0392b;
    --blue-light: #e8f0fe;
    --blue: #1a56a0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.65;
  }

  /* ── HEADER ── */
  header {
    background: var(--ink);
    color: white;
    padding: 2rem 3rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .header-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    color: white;
  }

  .header-logo span {
    color: var(--accent);
  }

  .header-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: #888;
    text-align: right;
    line-height: 1.8;
  }

  .header-title {
    width: 100%;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #333;
  }

  .header-title h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 2.6rem;
    letter-spacing: -0.03em;
    font-weight: 400;
    line-height: 1.1;
  }

  .header-title h1 em {
    font-style: italic;
    color: #aaa;
  }

  /* ── NAV ── */
  nav {
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    padding: 0 3rem;
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }

  nav a {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    padding: 0.9rem 1.1rem;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  nav a:hover { color: var(--ink); border-bottom-color: var(--accent); }

  /* ── LAYOUT ── */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  /* ── SECTIONS ── */
  .section {
    margin-bottom: 4rem;
    scroll-margin-top: 60px;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1.5px solid var(--border);
  }

  .section-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  /* ── CALLOUT ── */
  .callout {
    border-radius: 6px;
    padding: 0.9rem 1.1rem;
    margin-bottom: 1.25rem;
    font-size: 0.88rem;
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    line-height: 1.5;
  }

  .callout-icon { flex-shrink: 0; font-size: 1rem; }

  .callout.warn { background: var(--amber-light); border-left: 3px solid var(--amber); color: #6b4a00; }
  .callout.info { background: var(--blue-light); border-left: 3px solid var(--blue); color: #1a3a6b; }
  .callout.success { background: var(--green-light); border-left: 3px solid var(--green); color: #1a4a2e; }
  .callout.danger { background: var(--red-light); border-left: 3px solid var(--red); color: #7a1a1a; }
  .callout.tip { background: var(--accent-light); border-left: 3px solid var(--accent); color: #6b2800; }

  /* ── TABLES ── */
  .table-wrap { overflow-x: auto; margin-bottom: 1.5rem; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  thead th {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.6rem 0.9rem;
    border-bottom: 1.5px solid var(--border);
    text-align: left;
    background: var(--cream);
  }

  tbody td {
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  tbody tr:hover { background: var(--cream); }

  .mono { font-family: 'DM Mono', monospace; font-size: 0.82rem; }

  td a { color: var(--accent); text-decoration: none; }
  td a:hover { text-decoration: underline; }

  /* ── CARDS ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.2rem 1.4rem;
  }

  .card-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .card h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .card p { font-size: 0.86rem; color: #444; line-height: 1.55; }

  .case-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .case-card-header {
    background: var(--cream);
    padding: 0.7rem 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
  }

  .case-card-body { padding: 1rem; font-size: 0.88rem; }
  .case-card-body small { color: var(--muted); font-size: 0.82rem; display: block; margin-top: 0.4rem; }

  /* ── CHECKLIST ── */
  .checklist-section {
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .checklist-header {
    background: var(--ink);
    color: white;
    padding: 0.9rem 1.4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .checklist-header h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.15rem;
    font-weight: 400;
  }

  .progress-wrap { display: flex; align-items: center; gap: 0.75rem; }

  .progress-bar {
    width: 140px;
    height: 6px;
    background: #444;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.35s ease;
  }

  .progress-text {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: #aaa;
  }

  .checklist-group {
    padding: 0;
  }

  .checklist-group-title {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.9rem 1.4rem 0.4rem;
    border-top: 1px solid var(--border);
  }

  .checklist-group-title:first-child { border-top: none; }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
    transition: background 0.15s;
    user-select: none;
  }

  .checklist-item:hover { background: var(--paper); }

  .checklist-item.done { opacity: 0.5; }

  .checklist-item.done .item-label { text-decoration: line-through; }

  .checkbox {
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--border);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    background: white;
  }

  .checklist-item.done .checkbox {
    background: var(--green);
    border-color: var(--green);
  }

  .checkbox svg { display: none; }
  .checklist-item.done .checkbox svg { display: block; }

  .item-label { font-size: 0.88rem; line-height: 1.5; }
  .item-note { font-size: 0.78rem; color: var(--muted); margin-top: 0.15rem; font-style: italic; }
  .item-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    white-space: nowrap;
    margin-left: 0.5rem;
  }

  .checklist-footer {
    padding: 0.75rem 1.4rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: flex-end;
  }

  .btn-reset {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    background: none;
    border: 1px solid var(--border);
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-reset:hover { color: var(--ink); border-color: var(--ink); }

  /* ── PROCEDURE STEPS ── */
  .steps {
    counter-reset: step;
    margin-bottom: 1.5rem;
  }

  .step {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    align-items: flex-start;
  }

  .step-num {
    counter-increment: step;
    background: var(--ink);
    color: white;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .step-body { font-size: 0.9rem; padding-top: 0.2rem; }
  .step-body strong { font-weight: 600; }

  /* ── MAIL ── */
  .mail-block {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .mail-header {
    background: var(--cream);
    padding: 0.75rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .mail-subject {
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink);
  }

  .mail-attachment {
    font-size: 0.75rem;
    color: var(--amber);
    background: var(--amber-light);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-family: 'DM Mono', monospace;
  }

  .mail-body {
    padding: 1.2rem;
    font-size: 0.88rem;
    line-height: 1.7;
    white-space: pre-wrap;
    color: #333;
    border-bottom: 1px solid var(--border);
  }

  .mail-copy-btn {
    display: block;
    width: 100%;
    padding: 0.6rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    transition: background 0.2s, color 0.2s;
  }

  .mail-copy-btn:hover { background: var(--paper); color: var(--ink); }

  /* ── ANNUAIRE ── */
  .annuaire-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .contact-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .avatar {
    width: 36px;
    height: 36px;
    background: var(--ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: white;
    flex-shrink: 0;
  }

  .contact-info { min-width: 0; }
  .contact-name { font-weight: 600; font-size: 0.88rem; }
  .contact-role { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.25rem; }
  .contact-tel { font-family: 'DM Mono', monospace; font-size: 0.78rem; color: var(--accent); }

  /* ── POPAY ── */
  .popay-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 600px) {
    .popay-grid { grid-template-columns: 1fr; }
    header { padding: 1.5rem; }
    nav { padding: 0 1rem; }
    .container { padding: 2rem 1rem; }
    .header-title h1 { font-size: 1.9rem; }
    .annuaire-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
  }

  /* ── PILL ── */
  .pill {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.55rem;
    border-radius: 30px;
    border: 1px solid currentColor;
    margin-right: 0.4rem;
  }

  .pill.green { color: var(--green); }
  .pill.amber { color: var(--amber); }

  /* ── LINK ── */
  .ext-link {
    color: var(--accent);
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .ext-link::after { content: '↗'; font-size: 0.7rem; }
  .ext-link:hover { text-decoration: underline; }

  ul.doc-list { list-style: none; padding: 0; }
  ul.doc-list li {
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }
  ul.doc-list li::before { content: '—'; color: var(--muted); flex-shrink: 0; }

  .horizon { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  /* ── PARCOURS ── */
  .parcours {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 700px) { .parcours { grid-template-columns: 1fr 1fr; } }

  .parcours-step {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.9rem 1rem;
  }

  .parcours-step-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .parcours-step h4 { font-size: 0.88rem; font-weight: 600; margin-bottom: 0.3rem; }
  .parcours-step p { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

  /* footer */
  footer {
    background: var(--ink);
    color: #888;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    padding: 1.5rem;
    letter-spacing: 0.04em;
    line-height: 1.8;
  }

  footer span { color: #555; margin: 0 0.4rem; }
</style>
</head>
