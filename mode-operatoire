<script>
  // ── CHECKLISTS ──
  const totals = { creation: 20, reprise: 18, salarie: 10 };

  function updateProgress(listName) {
    const items = document.querySelectorAll(`[data-list="${listName}"]`);
    const done = [...items].filter(i => i.classList.contains('done')).length;
    const total = totals[listName];
    const pct = (done / total) * 100;
    document.getElementById(`prog-${listName}`).style.width = pct + '%';
    document.getElementById(`text-${listName}`).textContent = `${done} / ${total}`;
    // save
    const state = [...items].map(i => i.classList.contains('done'));
    localStorage.setItem(`cl-${listName}`, JSON.stringify(state));
  }

  function toggle(el) {
    el.classList.toggle('done');
    updateProgress(el.dataset.list);
  }

  function resetList(listName) {
    document.querySelectorAll(`[data-list="${listName}"]`).forEach(i => i.classList.remove('done'));
    updateProgress(listName);
  }

  // Restore from localStorage
  ['creation','reprise','salarie'].forEach(name => {
    const saved = localStorage.getItem(`cl-${name}`);
    if (saved) {
      const state = JSON.parse(saved);
      const items = document.querySelectorAll(`[data-list="${name}"]`);
      items.forEach((el, i) => { if (state[i]) el.classList.add('done'); });
    }
    updateProgress(name);
  });

  // ── COPY MAIL ──
  function copyMail(btn) {
    const text = btn.previousElementSibling.textContent.trim();
    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.textContent;
      btn.textContent = '✓ Copié !';
      setTimeout(() => btn.textContent = orig, 2000);
    });
  }
</script>
